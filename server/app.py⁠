from fastapi import FastAPI
from agents.storage_agent import storage_agent

app = FastAPI(title="ASI Agent Management API")

@app.get("/status")
def get_agent_status():
    """Returns basic visibility data regarding the cloud agent state."""
    return {
        "agent_name": storage_agent.name,
        "address": storage_agent.address,
        "status": "ACTIVE"
    }

@app.get("/metrics")
def get_storage_metrics():
    """Allows secure viewing of partition capacities without exposing exact secrets."""
    # access local storage via internal proxy if running
    return {
        "retention_policy": "90_DAYS_ROLLING",
        "msg": "Query storage via uagents context directly within execution bureau."
    }
